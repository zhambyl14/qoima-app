rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signed() && request.auth.uid == uid;
    }

    // True if the caller is the admin, OR an active seller whose ownerId == adminUid.
    function canAccess(adminUid) {
      return signed() && (
        request.auth.uid == adminUid ||
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data
              .get('ownerId', '') == adminUid &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data
              .get('joinStatus', '') == 'active'
        )
      );
    }

    // True if the update only touches inventory-tracking fields.
    // Used by client transactions (place / cancel online orders).
    function onlyStockFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['reserved_sizes', 'sizes_quantity']);
    }

    // True if the caller owns this order (UID match) or matches via phone JWT claim.
    function isOrderOwner() {
      return request.auth.uid == resource.data.get('clientUid', '') ||
             request.auth.token.get('phone_number', '') == resource.data.get('clientPhone', '');
    }

    // ── Users (Admins & Sellers) ──────────────────────────────────────────────
    match /users/{uid} {
      // Own profile; admin listing their sellers; active seller reading admin data.
      allow read: if signed() && (
        request.auth.uid == uid ||
        resource.data.get('ownerId', '') == request.auth.uid ||
        canAccess(uid)
      );
      allow write: if isOwner(uid);

      // ── Store settings ─────────────────────────────────────────────────────
      // Any signed user reads (client discovering stores).
      match /store/{storeId} {
        allow read:  if signed();
        allow write: if isOwner(uid);
      }

      // ── Products ───────────────────────────────────────────────────────────
      match /products/{productId} {
        allow read:  if signed();
        allow write: if canAccess(uid);

        // ── Batches ──────────────────────────────────────────────────────────
        match /batches/{batchId} {
          allow read:  if signed();
          allow write: if canAccess(uid);
          // Client order transactions may only touch reserved_sizes / sizes_quantity.
          allow update: if signed() && onlyStockFields();
        }
      }

      // ── Warehouses ─────────────────────────────────────────────────────────
      match /warehouses/{warehouseId} {
        allow read:           if signed();
        allow create, delete: if isOwner(uid);
        allow update:         if canAccess(uid);
      }

      // ── Sales history ──────────────────────────────────────────────────────
      match /sales_history/{saleId} {
        allow read, write: if canAccess(uid);
      }

      // ── Join requests ──────────────────────────────────────────────────────
      match /join_requests/{requestId} {
        allow read, update, delete: if isOwner(uid);
        allow create:               if signed();
      }

      // ── Stock transfers ────────────────────────────────────────────────────
      match /transfers/{transferId} {
        allow read, write: if canAccess(uid);
      }

      // ── Reservations (legacy pre-online-orders flow) ───────────────────────
      match /reservations/{reservationId} {
        allow read, write: if canAccess(uid);
      }
    }

    // ── Collection Group wildcards ────────────────────────────────────────────
    // Required for collectionGroup() queries that span the whole database.
    match /{path=**}/store/{storeDoc} {
      allow read: if signed();
    }
    match /{path=**}/products/{productDoc} {
      allow read: if signed();
    }
    match /{path=**}/batches/{batchDoc} {
      allow read: if signed();
    }
    match /{path=**}/warehouses/{warehouseDoc} {
      allow read: if signed();
    }

    // ── Clients (buyer profiles) ──────────────────────────────────────────────
    match /clients/{clientUid} {
      // Only the client themselves can read/write their profile.
      allow read, write: if isOwner(clientUid);
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Any authenticated user can place an order.
      allow create: if signed();

      // Client reads their own orders by UID (primary) or phone JWT claim (fallback).
      // Admin / seller reads their store's orders.
      allow read: if signed() && (
        isOrderOwner() ||
        canAccess(resource.data.get('adminUid', ''))
      );

      // Admin / seller: any update (confirm, cancel, complete, etc.).
      // Client: can ONLY set status = 'cancelled' and change nothing else.
      allow update: if signed() && (
        canAccess(resource.data.get('adminUid', '')) ||
        (
          isOrderOwner() &&
          request.resource.data.get('status', '') == 'cancelled' &&
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status'])
        )
      );

      allow delete: if false;
    }
  }
}
