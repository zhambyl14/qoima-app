rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Базалық функциялар ────────────────────────────────────────────────────

    function signed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signed() && request.auth.uid == uid;
    }

    function isAdminOfSeller(uid) {
      return signed() &&
        resource.data.get('role', '') == 'seller' &&
        resource.data.get('ownerId', '') == request.auth.uid;
    }

    function isPendingSellerForAdmin(uid) {
      return signed() &&
        resource.data.get('role', '') == 'seller' &&
        resource.data.get('pendingOwnerId', '') == request.auth.uid &&
        resource.data.get('joinStatus', '') == 'pending';
    }

    function canAccess(adminUid) {
      return signed() && (
        request.auth.uid == adminUid ||
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data
              .get('ownerId', '') == adminUid &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data
              .get('joinStatus', '') == 'active'
        )
      );
    }

    function onlyStockFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['reserved_sizes', 'sizes_quantity']);
    }

    function isOrderOwner() {
      return request.auth.uid == resource.data.get('clientUid', '') ||
             request.auth.token.get('phone_number', '') == resource.data.get('clientPhone', '');
    }

    function validSellerAdminUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'assignedWarehouseId',  // қойма бекіту
          'ownerId',              // admin uid жазу
          'joinStatus',           // active / rejected
          'pendingOwnerId',       // тазалау үшін (қабылдаған соң null)
        ]);
    }

    // ── Caller helper functions (Firestore get() — минимум рет шақырылады) ───

    function callerData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function callerRole() {
      return callerData().get('role', '');
    }

    function callerOwnerId() {
      return callerData().get('ownerId', '');
    }

    function callerJoinStatus() {
      return callerData().get('joinStatus', '');
    }

    function callerAssignedWarehouseId() {
      return callerData().get('assignedWarehouseId', '');
    }

    // Seller белгілі бір admin-ның белгілі бір қоймасына қол жеткізе ала ма?
    function sellerHasWarehouseAccess(adminUid, warehouseId) {
      return signed() &&
        callerRole() == 'seller' &&
        callerOwnerId() == adminUid &&
        callerJoinStatus() == 'active' &&
        callerAssignedWarehouseId() == warehouseId;
    }

    function isCallerSeller() {
      return signed() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        callerRole() == 'seller';
    }

    // Client тек completed ЕМЕС тапсырысты cancelled ете алады
    function clientCanCancel() {
      return isOrderOwner() &&
        resource.data.get('status', '') != 'completed' &&
        request.resource.data.get('status', '') == 'cancelled' &&
        request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status']);
    }

    // Seller тапсырысты өзінің қоймасы бойынша оқи/жаза алады
    function sellerCanAccessOrder(adminUid, warehouseId) {
      return signed() &&
        callerRole() == 'seller' &&
        callerOwnerId() == adminUid &&
        callerJoinStatus() == 'active' &&
        callerAssignedWarehouseId() == warehouseId;
    }

    // ── business_codes (adminUid → code lookup) ───────────────────────────────
    // Seller join кезінде admin-ды табу үшін
    match /business_codes/{code} {
      // Кез келген авторизацияланған пайдаланушы оқи алады (join flow)
      allow read: if signed();
      // Тек admin өзінің кодын жасай/өзгерте/жоя алады
      allow create: if signed() &&
        request.resource.data.adminUid == request.auth.uid;
      allow update, delete: if signed() &&
        resource.data.adminUid == request.auth.uid;
    }

    // ── Users (Admins & Sellers) ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if signed() && (
        request.auth.uid == uid ||
        resource.data.get('ownerId', '') == request.auth.uid ||
        canAccess(uid)
      );
      allow write: if isOwner(uid) ||
        ((isAdminOfSeller(uid) || isPendingSellerForAdmin(uid)) &&
          validSellerAdminUpdate());

      // ── Store settings ─────────────────────────────────────────────────────
      match /store/{storeId} {
        allow read:  if signed();
        allow write: if isOwner(uid);
      }

      // ── Products ───────────────────────────────────────────────────────────
      match /products/{productId} {
        allow read:  if signed();
        allow write: if canAccess(uid);

        // ── Batches ──────────────────────────────────────────────────────────
        match /batches/{batchId} {
          // Admin барлығын оқиды
          // Seller тек өз қоймасының batch-тарын оқиды
          allow read: if signed() && (
            request.auth.uid == uid ||
            !isCallerSeller() ||
            sellerHasWarehouseAccess(uid, resource.data.get('warehouseId', ''))
          );

          // Admin барлығын жаза алады
          // Seller тек өз қоймасына жаза алады
          allow write: if canAccess(uid) && (
            request.auth.uid == uid ||
            !isCallerSeller() ||
            sellerHasWarehouseAccess(uid, request.resource.data.get('warehouseId', ''))
          );

          // Client transaction (бронь жасау/болдырмау)
          // Seller тек өз қоймасының batch-тарын update ете алады
          allow update: if signed() && onlyStockFields() && (
            !isCallerSeller() ||
            sellerHasWarehouseAccess(uid, resource.data.get('warehouseId', ''))
          );
        }
      }

      // ── Warehouses ─────────────────────────────────────────────────────────
      match /warehouses/{warehouseId} {
        allow read:           if signed();
        allow create, delete: if isOwner(uid);
        allow update:         if canAccess(uid);
      }

      // ── Sales history ──────────────────────────────────────────────────────
      match /sales_history/{saleId} {
        allow read, write: if canAccess(uid);
      }

      // ── Join requests ──────────────────────────────────────────────────────
      // Seller кез келген admin-ның join_requests-ін жасай алады
      match /join_requests/{requestId} {
        allow create:               if signed();
        allow read, update, delete: if isOwner(uid);
      }

      // ── Stock transfers ────────────────────────────────────────────────────
      match /transfers/{transferId} {
        allow read, write: if canAccess(uid);
      }

      // ── Reservations ──────────────────────────────────────────────────────
      match /reservations/{reservationId} {
        allow read, write: if canAccess(uid);
      }
    }

    // ── Collection Group wildcards ────────────────────────────────────────────
    match /{path=**}/store/{storeDoc} {
      allow read: if signed();
    }
    match /{path=**}/products/{productDoc} {
      allow read: if signed();
    }
    match /{path=**}/batches/{batchDoc} {
      allow read: if signed();
    }
    match /{path=**}/warehouses/{warehouseDoc} {
      allow read: if signed();
    }

    // ── Clients (buyer profiles) ──────────────────────────────────────────────
    match /clients/{clientUid} {
      allow read, write: if isOwner(clientUid);
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Клиент тек өзінің uid-мен тапсырыс жасай алады
      allow create: if signed() &&
        request.resource.data.clientUid == request.auth.uid;

      // Кім оқи алады:
      // 1. Тапсырыс иесі (клиент)
      // 2. Admin (canAccess)
      // 3. Seller — тек өз қоймасының тапсырысы
      allow read: if signed() && (
        isOrderOwner() ||
        canAccess(resource.data.get('adminUid', '')) ||
        sellerCanAccessOrder(
          resource.data.get('adminUid', ''),
          resource.data.get('warehouseId', '')
        )
      );

      // Кім өзгерте алады:
      // 1. Admin (canAccess) — кез келген өзгеріс
      // 2. Seller — тек өз қоймасының тапсырысы
      // 3. Client — тек completed ЕМЕС тапсырысты cancelled ете алады
      allow update: if signed() && (
        canAccess(resource.data.get('adminUid', '')) ||
        sellerCanAccessOrder(
          resource.data.get('adminUid', ''),
          resource.data.get('warehouseId', '')
        ) ||
        clientCanCancel()
      );

      allow delete: if false;
    }
  }
}
